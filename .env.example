# Copy to .env and fill in real values. .env is gitignored.
# Read at build/dev time by Astro (Vite) — only PUBLIC_-prefixed vars reach the browser.

# Cloudflare Turnstile site key (public). Without it, InquiryForm.astro
# renders the "sending is unavailable" state instead of the widget.
# Use Cloudflare's always-pass testing key for local dev: 1x00000000000000000000AA
PUBLIC_TURNSTILE_SITE_KEY=
