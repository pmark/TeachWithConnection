---
import { site } from "../../data/site";
import { getSettingsCopy, list, text } from "../../data/content";

const copy = await getSettingsCopy("interface");
const inquiryTypes = list(copy, "form.inquiryTypes");
const clientMessages = JSON.stringify({
  submitting: text(copy, "form.submitting"),
  submit: text(copy, "form.submit"),
  defaultError: text(copy, "form.defaultError"),
  success: text(copy, "form.success"),
  networkError: text(copy, "form.networkError"),
  errors: {
    unsupported: text(copy, "error.unsupported"),
    too_large: text(copy, "error.tooLarge"),
    origin: text(copy, "error.origin"),
    rate_limited: text(copy, "error.rateLimited"),
    rejected: text(copy, "error.rejected"),
    validation: text(copy, "error.validation"),
    configuration: text(copy, "error.configuration"),
    verification: text(copy, "error.verification"),
    delivery: text(copy, "error.delivery"),
    method: text(copy, "error.method"),
  },
  fieldErrors: {
    required: text(copy, "field.required"),
    tooLongPrefix: text(copy, "field.tooLongPrefix"),
    tooLongSuffix: text(copy, "field.tooLongSuffix"),
    email: text(copy, "field.email"),
    inquiryType: text(copy, "field.inquiryType"),
  },
});

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const fieldClass =
  "min-h-11 w-full rounded-md border border-[#9b928a] bg-white px-3 py-2 font-normal text-charcoal focus:border-brand focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-brand";
---

<form
  id="inquiry-form"
  class="grid gap-5 rounded-md border border-line bg-white p-4 sm:p-6"
  action="/api/inquiry"
  method="post"
  aria-describedby="form-note form-status"
  data-inquiry-form
  data-messages={clientMessages}
>
  <p id="form-note" class="text-sm leading-6 text-stone">
    {text(copy, "form.note")}
  </p>

  <div class="hidden" aria-hidden="true">
    <label>
      {text(copy, "form.honeypotLabel")}
      <input name="website" tabindex="-1" autocomplete="off" />
    </label>
  </div>
  <input type="hidden" name="startedAt" value={Date.now()} />

  <div class="grid gap-5 sm:grid-cols-2">
    <label class="grid gap-2 text-sm font-semibold text-charcoal">
      {text(copy, "form.name")} <span class="font-normal text-stone">{text(copy, "form.required")}</span>
      <input class={fieldClass} name="name" autocomplete="name" required maxlength="100" aria-describedby="name-error" />
      <span id="name-error" class="hidden text-sm font-normal text-[#9f1d1d]" data-error-for="name"></span>
    </label>

    <label class="grid gap-2 text-sm font-semibold text-charcoal">
      {text(copy, "form.email")} <span class="font-normal text-stone">{text(copy, "form.required")}</span>
      <input class={fieldClass} name="email" type="email" autocomplete="email" required maxlength="254" aria-describedby="email-error" />
      <span id="email-error" class="hidden text-sm font-normal text-[#9f1d1d]" data-error-for="email"></span>
    </label>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <label class="grid gap-2 text-sm font-semibold text-charcoal">
      {text(copy, "form.organization")} <span class="font-normal text-stone">{text(copy, "form.required")}</span>
      <input class={fieldClass} name="organization" autocomplete="organization" required maxlength="150" aria-describedby="organization-error" />
      <span id="organization-error" class="hidden text-sm font-normal text-[#9f1d1d]" data-error-for="organization"></span>
    </label>

    <label class="grid gap-2 text-sm font-semibold text-charcoal">
      {text(copy, "form.role")}
      <input class={fieldClass} name="role" autocomplete="organization-title" maxlength="100" />
    </label>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <label class="grid gap-2 text-sm font-semibold text-charcoal">
      {text(copy, "form.location")}
      <input class={fieldClass} name="location" autocomplete="address-level2" maxlength="120" />
    </label>

    <label class="grid gap-2 text-sm font-semibold text-charcoal">
      {text(copy, "form.inquiryType")} <span class="font-normal text-stone">{text(copy, "form.required")}</span>
      <select class={fieldClass} name="inquiryType" required aria-describedby="inquiryType-error">
        <option value="">{text(copy, "form.chooseOne")}</option>
        {inquiryTypes.map((type) => <option value={type}>{type}</option>)}
      </select>
      <span id="inquiryType-error" class="hidden text-sm font-normal text-[#9f1d1d]" data-error-for="inquiryType"></span>
    </label>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <label class="grid gap-2 text-sm font-semibold text-charcoal">
      {text(copy, "form.timeline")}
      <input class={fieldClass} name="timeline" maxlength="120" />
    </label>

    <label class="grid gap-2 text-sm font-semibold text-charcoal">
      {text(copy, "form.audienceSize")}
      <input class={fieldClass} name="audienceSize" inputmode="numeric" maxlength="60" />
    </label>
  </div>

  <label class="grid gap-2 text-sm font-semibold text-charcoal">
    {text(copy, "form.message")} <span class="font-normal text-stone">{text(copy, "form.required")}</span>
    <textarea class={`${fieldClass} min-h-40`} name="message" required maxlength="5000" aria-describedby="message-error"></textarea>
    <span id="message-error" class="hidden text-sm font-normal text-[#9f1d1d]" data-error-for="message"></span>
  </label>

  {turnstileSiteKey ? (
    <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="light"></div>
  ) : (
    <p class="rounded-md border border-[#d7a700] bg-[#fff9df] p-4 text-sm leading-6 text-[#5f4c00]" role="status">
      {text(copy, "form.turnstileUnavailable")}
    </p>
  )}

  <p id="form-status" class="hidden rounded-md p-4 text-sm leading-6" role="status" tabindex="-1" data-form-status></p>

  <button
    class="min-h-11 rounded-md border border-brand bg-brand px-5 py-2.5 text-sm font-semibold text-white hover:border-brand-dark hover:bg-brand-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand disabled:cursor-not-allowed disabled:border-[#b9b0a8] disabled:bg-paper disabled:text-stone"
    type="submit"
    disabled={!turnstileSiteKey}
    data-submit-button
  >
    {text(copy, "form.submit")}
  </button>

  <p class="text-sm leading-6 text-stone">
    {text(copy, "form.fallbackPrefix")}
    <a class="inline-flex min-h-11 items-center font-semibold text-brand underline underline-offset-4" href={`${site.relatedPracticeUrl}/contact-us`}>
      {text(copy, "form.fallbackLink")}
    </a>.
  </p>
</form>

{turnstileSiteKey && (
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<script>
  const form = document.querySelector<HTMLFormElement>("[data-inquiry-form]");
  const status = form?.querySelector<HTMLElement>("[data-form-status]");
  const submitButton = form?.querySelector<HTMLButtonElement>("[data-submit-button]");
  const startedAtInput = form?.querySelector<HTMLInputElement>('input[name="startedAt"]');
  interface ClientMessages {
    submitting: string;
    submit: string;
    defaultError: string;
    success: string;
    networkError: string;
    errors: Record<string, string>;
    fieldErrors: Record<string, string>;
  }
  const messages = JSON.parse(form?.dataset.messages ?? "{}") as ClientMessages;
  if (startedAtInput) startedAtInput.value = String(Date.now());

  const resetTurnstile = () => {
    const turnstile = (window as Window & { turnstile?: { reset: () => void } }).turnstile;
    turnstile?.reset();
  };

  const clearErrors = () => {
    form?.querySelectorAll<HTMLElement>("[data-error-for]").forEach((element) => {
      element.textContent = "";
      element.classList.add("hidden");
    });
  };

  const showStatus = (message: string, success: boolean) => {
    if (!status) return;
    status.textContent = message;
    status.className = success
      ? "rounded-md border border-[#3c7a57] bg-[#edf8f1] p-4 text-sm leading-6 text-[#245137]"
      : "rounded-md border border-[#b73a3a] bg-[#fff1f1] p-4 text-sm leading-6 text-[#7d1818]";
    status.focus();
  };

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    clearErrors();
    if (!form.reportValidity() || !submitButton) return;

    submitButton.disabled = true;
    submitButton.textContent = messages.submitting;

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });
      const result = await response.json();

      if (!response.ok) {
        const fieldErrors = result.fieldErrors ?? {};
        Object.entries<string>(fieldErrors).forEach(([field, code]) => {
          const error = form.querySelector<HTMLElement>(`[data-error-for="${field}"]`);
          if (error) {
            const [kind, limit] = code.split(":");
            error.textContent = kind === "tooLong"
              ? `${messages.fieldErrors.tooLongPrefix} ${limit} ${messages.fieldErrors.tooLongSuffix}`
              : messages.fieldErrors[kind] ?? messages.defaultError;
            error.classList.remove("hidden");
          }
        });
        showStatus(messages.errors[result.code] ?? messages.defaultError, false);
        resetTurnstile();
        return;
      }

      form.reset();
      if (startedAtInput) startedAtInput.value = String(Date.now());
      resetTurnstile();
      showStatus(messages.success, true);
    } catch {
      showStatus(messages.networkError, false);
      resetTurnstile();
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = messages.submit;
    }
  });
</script>
