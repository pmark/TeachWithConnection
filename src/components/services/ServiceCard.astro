---
import ButtonLink from "../common/ButtonLink.astro";

interface Props {
  title: string;
  description: string;
  href: string;
  cta: string;
  image: {
    src: string;
    alt: string;
  };
}

const { title, description, href, cta, image } = Astro.props;
---

<article class="relative isolate flex min-h-[22rem] flex-col justify-end overflow-hidden rounded-md">
  <!-- Decorative: the title and description already convey what the photo shows. -->
  <img src={image.src} alt="" class="absolute inset-0 -z-20 h-full w-full object-cover" />
  <div class="absolute inset-0 -z-10 bg-footer-dark/80"></div>
  <div class="flex flex-col p-6">
    <h3 class="font-serif text-2xl leading-tight text-white">{title}</h3>
    <p class="mt-3 leading-7 text-white/90">{description}</p>
    <div class="mt-5">
      <ButtonLink href={href} variant="primary">{cta}</ButtonLink>
    </div>
  </div>
</article>
