---
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  background?: "white" | "surface";
  narrow?: boolean;
}

const {
  eyebrow,
  title,
  description,
  background = "white",
  narrow = false,
} = Astro.props;
---

<section class:list={["py-16 sm:py-20", background === "surface" && "bg-[#f7f7f7]"]}>
  <div class:list={["mx-auto px-4 sm:px-6", narrow ? "max-w-3xl" : "max-w-6xl"]}>
    {(eyebrow || title || description) && (
      <div class="mb-10 max-w-3xl">
        {eyebrow && (
          <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-[#157c93]">
            {eyebrow}
          </p>
        )}
        {title && (
          <h2 class="font-serif text-3xl leading-tight text-[#272727] sm:text-4xl">
            {title}
          </h2>
        )}
        {description && (
          <p class="mt-4 text-lg leading-8 text-[#4f4a45]">
            {description}
          </p>
        )}
      </div>
    )}
    <slot />
  </div>
</section>
