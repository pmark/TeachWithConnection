---
import ButtonLink from "./ButtonLink.astro";
import { getSettingsCopy, text } from "../../data/content";

interface Props {
  title?: string;
  description?: string;
  cta?: string;
}

const copy = await getSettingsCopy("site");
const {
  title = text(copy, "inquiry.title"),
  description = text(copy, "inquiry.description"),
  cta = text(copy, "inquiry.cta"),
} = Astro.props;
---

<section class="bg-[#157c93] py-14 text-white">
  <div class="mx-auto flex max-w-6xl flex-col gap-6 px-4 sm:px-6 md:flex-row md:items-center md:justify-between">
    <div class="max-w-3xl">
      <h2 class="font-serif text-3xl leading-tight sm:text-4xl">{title}</h2>
      <p class="mt-4 text-lg leading-8 text-white">{description}</p>
    </div>
    <div class="shrink-0">
      <ButtonLink href="/contact/" variant="secondary">{cta}</ButtonLink>
    </div>
  </div>
</section>
