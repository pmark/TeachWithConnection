---
interface Props {
  caption: string;
  aspect?: "square" | "video" | "portrait";
  class?: string;
}

const { caption, aspect = "video", class: className } = Astro.props;

const aspectClass = {
  square: "aspect-square",
  video: "aspect-[4/3]",
  portrait: "aspect-[3/4]",
}[aspect];
---

<figure
  class:list={[
    "flex flex-col items-center justify-center gap-2 rounded-md border border-dashed border-line bg-paper p-6 text-center",
    aspectClass,
    className,
  ]}
>
  <svg
    aria-hidden="true"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    class="h-8 w-8 text-stone"
  >
    <rect x="3" y="5" width="18" height="14" rx="2"></rect>
    <circle cx="9" cy="11" r="1.75"></circle>
    <path d="M3 16.5l5-4 4 3 4-5 5 4"></path>
  </svg>
  <figcaption>
    <span class="block text-xs font-semibold uppercase tracking-wide text-stone">Photo placeholder</span>
    <span class="mt-1 block text-sm text-slate">{caption}</span>
  </figcaption>
</figure>
