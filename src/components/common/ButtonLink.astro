---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "text";
}

const { href, variant = "primary" } = Astro.props;

const variants = {
  primary:
    "border-brand bg-brand text-white hover:border-brand-dark hover:bg-brand-dark",
  secondary:
    "border-brand bg-white text-brand hover:bg-paper",
  text: "border-transparent text-brand underline-offset-4 hover:underline",
};
---

<a
  href={href}
  class:list={[
    "inline-flex min-h-11 items-center justify-center rounded-md border px-5 py-2.5 text-sm font-semibold transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand",
    variants[variant],
  ]}
>
  <slot />
</a>
