---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "text";
}

const { href, variant = "primary" } = Astro.props;

const variants = {
  primary:
    "border-brand bg-gradient-to-b from-brand to-brand-dark text-white hover:border-brand-dark hover:from-brand-dark hover:to-brand-dark",
  secondary:
    "border-brand-text bg-surface text-brand-text hover:bg-paper",
  text: "border-transparent text-brand-text underline-offset-4 hover:underline",
};
---

<a
  href={href}
  class:list={[
    "inline-flex min-h-11 items-center justify-center rounded-md border px-5 py-2.5 text-sm font-semibold transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-text",
    variants[variant],
  ]}
>
  <slot />
</a>
