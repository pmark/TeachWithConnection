---
import ButtonLink from "../common/ButtonLink.astro";

interface Props {
  title: string;
  description: string;
  href: string;
  tags?: string[];
  cta: string;
  topicsAriaLabel: string;
}

const { title, description, href, tags = [], cta, topicsAriaLabel } = Astro.props;
---

<article class="rounded-md border border-line bg-white p-6">
  <h3 class="font-serif text-2xl text-charcoal">{title}</h3>
  <p class="mt-3 leading-7 text-slate">{description}</p>
  {tags.length > 0 && (
    <ul class="mt-5 flex flex-wrap gap-2" aria-label={topicsAriaLabel}>
      {tags.map((tag) => (
        <li class="rounded-md bg-paper px-3 py-1 text-sm text-stone">
          {tag}
        </li>
      ))}
    </ul>
  )}
  <div class="mt-6">
    <ButtonLink href={href} variant="secondary">{cta}</ButtonLink>
  </div>
</article>
