---
interface Props {
  quote: string;
  attribution: string;
}

const { quote, attribution } = Astro.props;
---

<figure class="relative py-8 pl-8 pr-6 sm:py-10 sm:pl-12 sm:pr-10">
  <span aria-hidden="true" class="absolute left-2 top-1 font-serif text-6xl leading-none text-clay-text sm:left-3 sm:text-7xl">&ldquo;</span>
  <blockquote class="relative font-serif text-2xl leading-9 text-charcoal">
    {quote}
  </blockquote>
  <figcaption class="mt-5 text-sm font-semibold text-stone">
    {attribution}
  </figcaption>
</figure>
