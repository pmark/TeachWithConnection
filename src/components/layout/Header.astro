---
import ButtonLink from "../common/ButtonLink.astro";
import { primaryNavigation } from "../../data/site";
import { getSettingsCopy, text } from "../../data/content";
const copy = await getSettingsCopy("site");
---

<header class="bg-brand">
  <div class="mx-auto max-w-6xl px-4 py-4 sm:px-6 lg:flex lg:items-center lg:justify-between lg:gap-4 lg:py-5">
    <div class="flex min-w-0 items-center justify-between gap-4">
      <a
        href="/"
        class="flex min-w-0 items-center gap-2 text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
      >
        <img
          src="/images/wc-logo.jpg"
          alt=""
          width="400"
          height="400"
          class="h-9 w-9 shrink-0 rounded-full object-cover sm:h-11 sm:w-11"
        />
        <span class="truncate font-serif text-2xl leading-none sm:text-3xl lg:text-2xl 2xl:text-3xl">{text(copy, "brand.wordmark")}</span>
      </a>
      <div class="flex items-center gap-2 lg:hidden">
        <ButtonLink href="/contact/" variant="inverse">{text(copy, "header.inquire")}</ButtonLink>
      </div>
    </div>

    <details class="group mt-4 border-t border-white/25 pt-3 lg:hidden">
      <summary class="flex min-h-11 cursor-pointer list-none items-center justify-between rounded-md px-2 font-semibold text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white [&::-webkit-details-marker]:hidden">
        {text(copy, "header.menu")}
        <span aria-hidden="true" class="text-xl group-open:rotate-45">+</span>
      </summary>
      <nav aria-label={text(copy, "header.primaryNavigationAriaLabel")}>
        <ul class="mt-2 grid text-sm font-semibold uppercase tracking-wide text-white/90">
          {primaryNavigation.map((item) => (
            <li>
              <a
                href={item.href}
                class="flex min-h-11 items-center rounded-md px-2 underline-offset-4 hover:bg-white/10 hover:text-white hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
              >
                {text(copy, item.labelKey)}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </details>

    <div class="hidden items-center gap-4 lg:flex">
      <nav aria-label={text(copy, "header.primaryNavigationAriaLabel")}>
        <ul class="flex items-center gap-4 text-sm font-semibold uppercase tracking-wide text-white/90">
          {primaryNavigation.map((item) => (
            <li>
              <a
                href={item.href}
                class="inline-flex min-h-11 items-center px-1 underline-offset-4 hover:text-white hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
              >
                {text(copy, item.labelKey)}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <ButtonLink href="/contact/" variant="inverse">{text(copy, "header.inquire")}</ButtonLink>
    </div>
  </div>
</header>
