---
import ButtonLink from "../common/ButtonLink.astro";
import { primaryNavigation } from "../../data/site";
import { getSettingsCopy, text } from "../../data/content";
const copy = await getSettingsCopy("site");
---

<header class="border-b border-line bg-white">
  <div class="mx-auto max-w-6xl px-4 py-4 sm:px-6 lg:flex lg:items-center lg:justify-between lg:gap-8 lg:py-5">
    <div class="flex items-center justify-between gap-4">
      <a
        href="/"
        class="flex min-w-0 flex-col items-start gap-1 text-charcoal focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand"
      >
        <img
          src="/images/logo-small-785x240.jpg"
          alt={text(copy, "brand.name")}
          width="785"
          height="240"
          class="h-9 w-auto sm:h-11"
        />
        <span class="block truncate text-xs text-stone sm:text-sm">
          {text(copy, "brand.person")}, {text(copy, "brand.credentials")}
        </span>
      </a>
      <div class="lg:hidden">
        <ButtonLink href="/contact/">{text(copy, "header.inquire")}</ButtonLink>
      </div>
    </div>

    <details class="group mt-4 border-t border-line pt-3 lg:hidden">
      <summary class="flex min-h-11 cursor-pointer list-none items-center justify-between rounded-md px-2 font-semibold text-charcoal focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand [&::-webkit-details-marker]:hidden">
        {text(copy, "header.menu")}
        <span aria-hidden="true" class="text-xl group-open:rotate-45">+</span>
      </summary>
      <nav aria-label={text(copy, "header.primaryNavigationAriaLabel")}>
        <ul class="mt-2 grid text-sm font-semibold text-graphite">
          {primaryNavigation.map((item) => (
            <li>
              <a
                href={item.href}
                class="flex min-h-11 items-center rounded-md px-2 underline-offset-4 hover:bg-paper hover:text-brand hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
              >
                {text(copy, item.labelKey)}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </details>

    <div class="hidden items-center gap-5 lg:flex">
      <nav aria-label={text(copy, "header.primaryNavigationAriaLabel")}>
        <ul class="flex items-center gap-5 text-sm font-semibold text-graphite">
          {primaryNavigation.map((item) => (
            <li>
              <a
                href={item.href}
                class="inline-flex min-h-11 items-center px-1 underline-offset-4 hover:text-brand hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand"
              >
                {text(copy, item.labelKey)}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <ButtonLink href="/contact/">{text(copy, "header.inquire")}</ButtonLink>
    </div>
  </div>
</header>
