---
import ButtonLink from "../common/ButtonLink.astro";
import { primaryNavigation } from "../../data/site";
import { getSettingsCopy, text } from "../../data/content";
const copy = await getSettingsCopy("site");
---

<header class="border-b border-[#e8e2dc] bg-white">
  <div class="mx-auto max-w-6xl px-4 py-4 sm:px-6 lg:flex lg:items-center lg:justify-between lg:gap-8 lg:py-5">
    <div class="flex items-center justify-between gap-4">
      <a
        href="/"
        class="min-w-0 text-[#272727] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#157c93]"
      >
        <span class="block font-serif text-2xl leading-none sm:text-3xl">{text(copy, "brand.name")}</span>
        <span class="mt-1 block truncate text-xs text-[#5d5751] sm:text-sm">
          {text(copy, "brand.person")}, {text(copy, "brand.credentials")}
        </span>
      </a>
      <div class="lg:hidden">
        <ButtonLink href="/contact/">{text(copy, "header.inquire")}</ButtonLink>
      </div>
    </div>

    <details class="group mt-4 border-t border-[#e8e2dc] pt-3 lg:hidden">
      <summary class="flex min-h-11 cursor-pointer list-none items-center justify-between rounded-md px-2 font-semibold text-[#272727] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#157c93] [&::-webkit-details-marker]:hidden">
        {text(copy, "header.menu")}
        <span aria-hidden="true" class="text-xl group-open:rotate-45">+</span>
      </summary>
      <nav aria-label={text(copy, "header.primaryNavigationAriaLabel")}>
        <ul class="mt-2 grid text-sm font-semibold text-[#3c3834]">
          {primaryNavigation.map((item) => (
            <li>
              <a
                href={item.href}
                class="flex min-h-11 items-center rounded-md px-2 underline-offset-4 hover:bg-[#f7f7f7] hover:text-[#157c93] hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#157c93]"
              >
                {text(copy, item.labelKey)}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </details>

    <div class="hidden items-center gap-5 lg:flex">
      <nav aria-label={text(copy, "header.primaryNavigationAriaLabel")}>
        <ul class="flex items-center gap-5 text-sm font-semibold text-[#3c3834]">
          {primaryNavigation.map((item) => (
            <li>
              <a
                href={item.href}
                class="inline-flex min-h-11 items-center px-1 underline-offset-4 hover:text-[#157c93] hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#157c93]"
              >
                {text(copy, item.labelKey)}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <ButtonLink href="/contact/">{text(copy, "header.inquire")}</ButtonLink>
    </div>
  </div>
</header>
