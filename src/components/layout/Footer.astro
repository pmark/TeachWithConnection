---
import ThemeToggleButton from "../common/ThemeToggleButton.astro";
import { footerNavigation, site, socialLinks } from "../../data/site";
import { getSettingsCopy, text } from "../../data/content";
const copy = await getSettingsCopy("site");
---

<footer class="border-t border-line bg-gradient-to-b from-footer to-footer-dark text-white">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 md:grid-cols-[1.2fr_2fr]">
    <div>
      <p class="font-serif text-3xl">{text(copy, "brand.name")}</p>
      <p class="mt-3 max-w-md text-sm leading-6 text-[#ddd6cf]">
        {text(copy, "footer.description")}
      </p>
      <p class="mt-4 max-w-md text-sm leading-6 text-[#ddd6cf]">
        {text(copy, "footer.relatedPracticePrefix")}
        <a class="inline-flex min-h-11 items-center underline underline-offset-4 hover:text-white" href={site.relatedPracticeUrl}>{text(copy, "footer.relatedPracticeLabel")}</a>.
      </p>
    </div>

    <nav aria-label={text(copy, "footer.navigationAriaLabel")}>
      <ul class="grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-3">
        {footerNavigation.map((item) => (
          <li>
            <a
              href={item.href}
              class="inline-flex min-h-11 items-center px-1 text-[#f6f2ec] underline-offset-4 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
            >
              {text(copy, item.labelKey)}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-5 text-sm text-[#ddd6cf] sm:px-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex flex-wrap items-center gap-x-3">
        <p>&copy; {new Date().getFullYear()} {text(copy, "brand.legalName")}</p>
        <nav aria-label={text(copy, "footer.socialNavigationAriaLabel")}>
          <ul class="flex items-center gap-1">
            {socialLinks.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="inline-flex size-11 items-center justify-center rounded-full hover:bg-white/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
                  target="_blank"
                  rel="me noopener noreferrer"
                  aria-label={text(copy, item.labelKey)}
                >
                  <img src={item.icon} alt="" width="86" height="86" class="size-6" />
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <ThemeToggleButton label={text(copy, "header.themeToggle")} />
      </div>
      <p>{text(copy, "footer.closing")}</p>
    </div>
  </div>
</footer>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach((button) => {
    button.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
  });
</script>
