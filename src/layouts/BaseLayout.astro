---
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import "../styles/global.css";
import { site } from "../data/site";
import { getSettingsCopy, list, text } from "../data/content";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  noindex?: boolean;
  socialImage?: string;
  titleSuffix?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  noindex = false,
  socialImage,
  titleSuffix = true,
  structuredData = [],
} = Astro.props;
const copy = await getSettingsCopy("site");
const pageTitle = titleSuffix ? `${title} | ${text(copy, "brand.name")}` : title;
const canonicalUrl = new URL(canonicalPath, site.url).toString();
const socialImageUrl = socialImage ? new URL(socialImage, site.url).toString() : undefined;
const additionalStructuredData = Array.isArray(structuredData) ? structuredData : [structuredData];
const breadcrumbData = canonicalPath === "/" ? [] : [
  {
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: text(copy, "breadcrumb.home"),
        item: site.url,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: title,
        item: canonicalUrl,
      },
    ],
  },
];
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${site.url}/#organization`,
      name: text(copy, "brand.name"),
      legalName: text(copy, "brand.legalName"),
      url: site.url,
      founder: { "@id": `${site.url}/#katie-statman-weil` },
    },
    {
      "@type": "Person",
      "@id": `${site.url}/#katie-statman-weil`,
      name: text(copy, "brand.person"),
      honorificSuffix: text(copy, "brand.credentials"),
      url: `${site.url}/about/`,
      sameAs: [site.relatedPracticeUrl],
      worksFor: { "@id": `${site.url}/#organization` },
      jobTitle: list(copy, "schema.jobTitles"),
    },
    {
      "@type": "WebSite",
      "@id": `${site.url}/#website`,
      name: text(copy, "schema.websiteName"),
      url: site.url,
      description: text(copy, "brand.description"),
      publisher: { "@id": `${site.url}/#organization` },
    },
    ...breadcrumbData,
    ...additionalStructuredData,
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function () {
        var stored = localStorage.getItem("theme");
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var isDark = stored === "dark" || (!stored && prefersDark);
        document.documentElement.classList.toggle("dark", isDark);
      })();
    </script>
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1f1c18" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={text(copy, "schema.websiteName")} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {socialImageUrl && <meta property="og:image" content={socialImageUrl} />}
    <meta name="twitter:card" content={socialImageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {socialImageUrl && <meta name="twitter:image" content={socialImageUrl} />}
    <title>{pageTitle}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen bg-surface text-charcoal antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
