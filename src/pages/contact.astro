---
import InquiryForm from "../components/forms/InquiryForm.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Inquiry form for professional development, workshops, keynotes, and consultation with Katie Statman-Weil and With Connection."
>
  <PageHero
    eyebrow="Inquiry"
    title="Tell Katie what your team is facing"
    description="Share your organization, audience, timeline, and the classroom or event needs you want to explore."
  />

  <Section
    eyebrow="Form"
    title="Inquiry form"
    description="Share the essentials below. The secure inquiry service validates your submission and sends it directly to Katie."
  >
    <div class="max-w-3xl">
      <InquiryForm />
    </div>
  </Section>
</BaseLayout>
