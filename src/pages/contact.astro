---
import InquiryForm from "../components/forms/InquiryForm.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageCopy, text } from "../data/content";

const copy = await getPageCopy("contact");
---

<BaseLayout
  title={text(copy, "seo.title")}
  description={text(copy, "seo.description")}
>
  <PageHero
    eyebrow={text(copy, "hero.eyebrow")}
    title={text(copy, "hero.title")}
    description={text(copy, "hero.description")}
  />

  <Section
    eyebrow={text(copy, "form.eyebrow")}
    title={text(copy, "form.title")}
    description={text(copy, "form.description")}
  >
    <div class="max-w-3xl">
      <InquiryForm />
    </div>
  </Section>
</BaseLayout>
