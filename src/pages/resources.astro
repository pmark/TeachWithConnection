---
import ButtonLink from "../components/common/ButtonLink.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import ResourceCard from "../components/content/ResourceCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getPageCopy, text } from "../data/content";

const resources = await getCollection("resources");
const copy = await getPageCopy("resources");
---

<BaseLayout
  title={text(copy, "seo.title")}
  description={text(copy, "seo.description")}
  noindex={resources.length === 0}
>
  <PageHero
    eyebrow={text(copy, "hero.eyebrow")}
    title={text(copy, "hero.title")}
    description={text(copy, "hero.description")}
  >
    <div class="mt-8">
      <ButtonLink href="/contact/" variant="secondary">{text(copy, "hero.cta")}</ButtonLink>
    </div>
  </PageHero>

  <Section
    eyebrow={text(copy, "library.eyebrow")}
    title={resources.length > 0 ? text(copy, "library.availableTitle") : text(copy, "library.emptyTitle")}
    description={text(copy, "library.description")}
  >
    {resources.length > 0 ? (
      <div class="grid gap-5 md:grid-cols-2">
        {resources.map(({ data, id }) => (
          <ResourceCard
            title={data.title}
            description={data.description}
            href={`/resources/${id.replace(/\.md$/, "")}/`}
            tags={data.tags}
            cta={text(copy, "card.cta")}
            topicsAriaLabel={text(copy, "card.topicsAriaLabel")}
          />
        ))}
      </div>
    ) : (
      <div class="rounded-md border border-[#e8e2dc] bg-white p-6">
        <p class="leading-7 text-[#4f4a45]">
          {text(copy, "library.empty")}
        </p>
        <div class="mt-6">
          <ButtonLink href="/articles/" variant="secondary">{text(copy, "library.emptyCta")}</ButtonLink>
        </div>
      </div>
    )}
  </Section>
</BaseLayout>
