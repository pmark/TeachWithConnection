---
import ButtonLink from "../components/common/ButtonLink.astro";
import InquiryCta from "../components/common/InquiryCta.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageCopy, list, text } from "../data/content";
const copy = await getPageCopy("about");
---

<BaseLayout
  title={text(copy, "seo.title")}
  description={text(copy, "seo.description")}
>
  <PageHero
    eyebrow={text(copy, "hero.eyebrow")}
    title={text(copy, "hero.title")}
    description={text(copy, "hero.description")}
  >
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <ButtonLink href="/contact/">{text(copy, "hero.primaryCta")}</ButtonLink>
      <ButtonLink href="/publications/" variant="secondary">{text(copy, "hero.secondaryCta")}</ButtonLink>
    </div>
  </PageHero>

  <Section
    eyebrow={text(copy, "background.eyebrow")}
    title={text(copy, "background.title")}
  >
    <div class="grid gap-8 lg:grid-cols-[1fr_1fr]">
      <div class="space-y-5 leading-8 text-[#4f4a45]">
        {list(copy, "background.paragraphs").map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <div class="rounded-md border border-[#e8e2dc] bg-white p-6">
        <h3 class="font-serif text-2xl leading-tight text-[#272727]">
          {text(copy, "philosophy.title")}
        </h3>
        <ul class="mt-6 grid gap-4">
          {list(copy, "philosophy.items").map((item) => (
            <li class="border-l-4 border-[#157c93] pl-4 leading-7 text-[#4f4a45]">
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Section>

  <Section
    background="surface"
    eyebrow={text(copy, "credibility.eyebrow")}
    title={text(copy, "credibility.title")}
    description={text(copy, "credibility.description")}
  >
    <ButtonLink href="/publications/" variant="secondary">{text(copy, "credibility.cta")}</ButtonLink>
  </Section>

  <InquiryCta />
</BaseLayout>
