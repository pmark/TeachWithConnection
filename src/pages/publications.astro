---
import ButtonLink from "../components/common/ButtonLink.astro";
import InquiryCta from "../components/common/InquiryCta.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const proofTypeOrder = {
  publication: 1,
  award: 2,
  credential: 3,
  appearance: 4,
  logo: 5,
};

const publicationProof = (await getCollection("proof"))
  .filter(({ data }) => data.type === "publication" || data.type === "award")
  .sort(
    (first, second) =>
      proofTypeOrder[first.data.type] - proofTypeOrder[second.data.type] ||
      first.data.title.localeCompare(second.data.title),
  );
---

<BaseLayout
  title="Publications"
  description="Publication proof for Katie Statman-Weil, including Trauma Responsive Strategies for Early Childhood and NAEYC writing."
>
  <PageHero
    eyebrow="Publications"
    title="Books, articles, and publication proof"
    description="Katie's publication record supports the professional development work with early childhood educators, organizations, and conference audiences."
  >
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <ButtonLink href="/contact/">Ask about professional development</ButtonLink>
      <ButtonLink href="/about/" variant="secondary">About Katie</ButtonLink>
    </div>
  </PageHero>

  <Section
    eyebrow="Proof"
    title="Source-backed publications and recognition"
    description="These entries are seeded from the existing With Connection bookstore and linked to publisher or publication pages when available."
  >
    <ul class="grid gap-4 md:grid-cols-2">
      {publicationProof.map(({ data }) => (
        <li class="rounded-md border border-[#e8e2dc] bg-white p-5">
          <p class="text-sm font-semibold uppercase tracking-wide text-[#157c93]">
            {data.type}
          </p>
          <h3 class="mt-3 font-serif text-2xl leading-tight text-[#272727]">
            {data.title}
          </h3>
          <p class="mt-3 leading-7 text-[#4f4a45]">{data.description}</p>
          {data.href && (
            <div class="mt-5">
              <ButtonLink href={data.href} variant="text">Open publication link</ButtonLink>
            </div>
          )}
        </li>
      ))}
    </ul>
  </Section>

  <InquiryCta />
</BaseLayout>
