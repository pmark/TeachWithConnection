---
import ButtonLink from "../components/common/ButtonLink.astro";
import InquiryCta from "../components/common/InquiryCta.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getPageCopy, text } from "../data/content";

const proofTypeOrder = {
  publication: 1,
  award: 2,
  credential: 3,
  appearance: 4,
  logo: 5,
};

const publicationProof = (await getCollection("proof"))
  .filter(({ data }) => data.type === "publication" || data.type === "award")
  .sort(
    (first, second) =>
      proofTypeOrder[first.data.type] - proofTypeOrder[second.data.type] ||
      first.data.title.localeCompare(second.data.title),
  );
const copy = await getPageCopy("publications");
---

<BaseLayout
  title={text(copy, "seo.title")}
  description={text(copy, "seo.description")}
>
  <PageHero
    eyebrow={text(copy, "hero.eyebrow")}
    title={text(copy, "hero.title")}
    description={text(copy, "hero.description")}
  >
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <ButtonLink href="/contact/">{text(copy, "hero.primaryCta")}</ButtonLink>
      <ButtonLink href="/about/" variant="secondary">{text(copy, "hero.secondaryCta")}</ButtonLink>
    </div>
  </PageHero>

  <Section
    eyebrow={text(copy, "proof.eyebrow")}
    title={text(copy, "proof.title")}
    description={text(copy, "proof.description")}
  >
    <ul class="grid gap-4 md:grid-cols-2">
      {publicationProof.map(({ data }) => (
        <li class="rounded-md border border-line bg-surface p-5">
          <p class="text-sm font-semibold uppercase tracking-wide text-brand-text">
            {data.type}
          </p>
          <h3 class="mt-3 font-serif text-2xl leading-tight text-charcoal">
            {data.title}
          </h3>
          <p class="mt-3 leading-7 text-slate">{data.description}</p>
          {data.href && (
            <div class="mt-5">
              <ButtonLink href={data.href} variant="text">{text(copy, "proof.linkCta")}</ButtonLink>
            </div>
          )}
        </li>
      ))}
    </ul>
  </Section>

  <InquiryCta />
</BaseLayout>
