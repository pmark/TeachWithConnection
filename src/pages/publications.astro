    eyebrow="Publications"
    title="Books, articles, and publication proof"
    description="This page should highlight Katie's Redleaf Press book, NAEYC Young Children article, Gold Excel Award, and related publication links."
  >
    <ul class="grid gap-4 md:grid-cols-2">
      <li class="rounded-md border border-[#e8e2dc] bg-white p-5">
        <cite>Trauma Responsive Strategies for Early Childhood</cite>
      </li>
      <li class="rounded-md border border-[#e8e2dc] bg-white p-5">
        <cite>Creating Trauma Sensitive Classrooms</cite> for NAEYC <cite>Young Children</cite>
      </li>
    </ul>
  </Section>
  <InquiryCta />
</BaseLayout>
