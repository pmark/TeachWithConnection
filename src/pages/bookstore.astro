---
import ButtonLink from "../components/common/ButtonLink.astro";
import InquiryCta from "../components/common/InquiryCta.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import TestimonialQuote from "../components/proof/TestimonialQuote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { getPageCopy, getTestimonial, list, text } from "../data/content";

const bookUrl = "https://www.redleafpress.org/Trauma-Responsive-Strategies-for-Early-Childhood-P2503.aspx";
const amazonUrl = "https://www.amazon.com/Trauma-Responsive-Strategies-Early-Childhood-Statman-Weil/dp/1605546631";
const copy = await getPageCopy("bookstore");
const bookDescription = text(copy, "book.description");
const reviews = await Promise.all(
  ["bookstore-review-goodreads-1", "bookstore-review-amazon-1", "bookstore-review-goodreads-2", "bookstore-review-amazon-2"].map(
    (id) => getTestimonial(id),
  ),
);

const bookStructuredData = {
  "@type": ["Book", "Product"],
  "@id": `${site.url}/bookstore/#trauma-responsive-strategies`,
  name: text(copy, "book.title"),
  description: bookDescription,
  datePublished: "2020",
  author: { "@id": `${site.url}/#katie-statman-weil` },
  brand: { "@id": `${site.url}/#organization` },
  url: `${site.url}/bookstore/`,
  sameAs: bookUrl,
};
---

<BaseLayout
  title={text(copy, "seo.title")}
  description={text(copy, "seo.description")}
  structuredData={bookStructuredData}
>
  <PageHero
    eyebrow={text(copy, "hero.eyebrow")}
    title={text(copy, "hero.title")}
    description={text(copy, "hero.description")}
  />

  <Section eyebrow={text(copy, "book.eyebrow")} title={text(copy, "book.title")}>
    <article class="grid gap-8 rounded-md border border-line bg-surface p-5 sm:p-7 lg:grid-cols-[1fr_0.75fr] lg:items-start">
      <div>
        <img
          src="/images/book-cover-trauma-responsive-strategies-for-early-childhood.jpg"
          alt="Book cover: Trauma-Responsive Strategies for Early Childhood by Katie Statman-Weil, EdD, LCSW"
          width="361"
          height="522"
          class="aspect-[361/522] w-full max-w-40 rounded-md object-cover sm:max-w-48"
        />
        <p class="mt-5 text-sm font-semibold uppercase tracking-wide text-brand-text">{text(copy, "book.meta")}</p>
        <p class="mt-4 leading-8 text-slate">{bookDescription}</p>
        <p class="mt-4 leading-8 text-slate">
          {text(copy, "book.secondaryDescription")}
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <ButtonLink href={bookUrl}>{text(copy, "book.primaryCta")}</ButtonLink>
          <ButtonLink href={amazonUrl} variant="secondary">{text(copy, "book.amazonCta")}</ButtonLink>
          <ButtonLink href="/#professional-development" variant="secondary">{text(copy, "book.secondaryCta")}</ButtonLink>
          <ButtonLink href="/resources/" variant="secondary">{text(copy, "book.resourcesCta")}</ButtonLink>
        </div>
      </div>
      <aside class="rounded-md bg-paper p-5" aria-label={text(copy, "book.topicsAriaLabel")}>
        <h2 class="font-serif text-2xl leading-tight text-charcoal">{text(copy, "book.topicsTitle")}</h2>
        <ul class="mt-5 grid gap-3 leading-7 text-slate">
          {list(copy, "book.topics").map((topic) => <li>{topic}</li>)}
        </ul>
      </aside>
    </article>
  </Section>

  <Section
    eyebrow={text(copy, "testimonial.eyebrow")}
    title={text(copy, "testimonial.title")}
  >
    <div class="grid gap-4">
      {reviews.map((review) => (
        <TestimonialQuote quote={review.quote} attribution={review.attribution} />
      ))}
    </div>
  </Section>

  <Section
    background="surface"
    eyebrow={text(copy, "related.eyebrow")}
    title={text(copy, "related.title")}
    description={text(copy, "related.description")}
  >
    <p class="leading-8 text-slate">{text(copy, "related.paragraph1")}</p>
    <p class="mt-4 leading-8 text-slate">{text(copy, "related.paragraph2")}</p>
    <div class="mt-6">
      <ButtonLink href="/publications/" variant="secondary">{text(copy, "related.cta")}</ButtonLink>
    </div>
  </Section>


  <InquiryCta title={text(copy, "inquiry.title")} />
</BaseLayout>
