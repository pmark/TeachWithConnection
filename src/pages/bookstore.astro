---
import ButtonLink from "../components/common/ButtonLink.astro";
import InquiryCta from "../components/common/InquiryCta.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { getPageCopy, list, text } from "../data/content";

const bookUrl = "https://www.redleafpress.org/Trauma-Responsive-Strategies-for-Early-Childhood-P2503.aspx";
const copy = await getPageCopy("bookstore");
const bookDescription = text(copy, "book.description");

const bookStructuredData = {
  "@type": ["Book", "Product"],
  "@id": `${site.url}/bookstore/#trauma-responsive-strategies`,
  name: text(copy, "book.title"),
  description: bookDescription,
  datePublished: "2020",
  author: { "@id": `${site.url}/#katie-statman-weil` },
  brand: { "@id": `${site.url}/#organization` },
  url: `${site.url}/bookstore/`,
  sameAs: bookUrl,
};
---

<BaseLayout
  title={text(copy, "seo.title")}
  description={text(copy, "seo.description")}
  structuredData={bookStructuredData}
>
  <PageHero
    eyebrow={text(copy, "hero.eyebrow")}
    title={text(copy, "hero.title")}
    description={text(copy, "hero.description")}
  />

  <Section eyebrow={text(copy, "book.eyebrow")} title={text(copy, "book.title")}>
    <article class="grid gap-8 rounded-md border border-[#e8e2dc] bg-white p-5 sm:p-7 lg:grid-cols-[1fr_0.75fr] lg:items-start">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-[#157c93]">{text(copy, "book.meta")}</p>
        <p class="mt-4 leading-8 text-[#4f4a45]">{bookDescription}</p>
        <p class="mt-4 leading-8 text-[#4f4a45]">
          {text(copy, "book.secondaryDescription")}
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <ButtonLink href={bookUrl}>{text(copy, "book.primaryCta")}</ButtonLink>
          <ButtonLink href="/#professional-development" variant="secondary">{text(copy, "book.secondaryCta")}</ButtonLink>
        </div>
      </div>
      <aside class="rounded-md bg-[#f7f7f7] p-5" aria-label={text(copy, "book.topicsAriaLabel")}>
        <h2 class="font-serif text-2xl leading-tight text-[#272727]">{text(copy, "book.topicsTitle")}</h2>
        <ul class="mt-5 grid gap-3 leading-7 text-[#4f4a45]">
          {list(copy, "book.topics").map((topic) => <li>{topic}</li>)}
        </ul>
      </aside>
    </article>
  </Section>

  <Section
    background="surface"
    eyebrow={text(copy, "related.eyebrow")}
    title={text(copy, "related.title")}
    description={text(copy, "related.description")}
  >
    <ButtonLink href="/publications/" variant="secondary">{text(copy, "related.cta")}</ButtonLink>
  </Section>

  <InquiryCta title={text(copy, "inquiry.title")} />
</BaseLayout>
