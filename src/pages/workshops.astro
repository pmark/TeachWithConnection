---
import ButtonLink from "../components/common/ButtonLink.astro";
import InquiryCta from "../components/common/InquiryCta.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { createServiceStructuredData } from "../data/site";
import { cards, getPageCopy, getSettingsCopy, list, text } from "../data/content";

const copy = await getPageCopy("workshops");
const description = text(copy, "seo.description");
---

<BaseLayout
  title={text(copy, "seo.title")}
  description={description}
  structuredData={createServiceStructuredData(text(copy, "structuredData.name"), description, "/workshops/", text(await getSettingsCopy("site"), "schema.serviceAudience"))}
>
  <PageHero
    eyebrow={text(copy, "hero.eyebrow")}
    title={text(copy, "hero.title")}
    description={text(copy, "hero.description")}
  >
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <ButtonLink href="/contact/">{text(copy, "hero.primaryCta")}</ButtonLink>
      <ButtonLink href="/#professional-development" variant="secondary">
        {text(copy, "hero.secondaryCta")}
      </ButtonLink>
    </div>
  </PageHero>

  <Section
    eyebrow={text(copy, "topics.eyebrow")}
    title={text(copy, "topics.title")}
    description={text(copy, "topics.description")}
  >
    <ul class="grid gap-4 md:grid-cols-2">
      {cards(copy, "topics.items").map((topic) => (
        <li class="rounded-md border border-line bg-white p-5">
          <h3 class="font-serif text-2xl leading-tight text-charcoal">
            {topic.title}
          </h3>
          <p class="mt-3 leading-7 text-slate">{topic.description}</p>
        </li>
      ))}
    </ul>
  </Section>

  <Section
    background="surface"
    eyebrow={text(copy, "lens.eyebrow")}
    title={text(copy, "lens.title")}
    description={text(copy, "lens.description")}
  >
    <ul class="grid gap-4 md:grid-cols-2">
      {list(copy, "lens.items").map((item) => (
        <li class="border-l-4 border-brand bg-white px-5 py-4 leading-7 text-graphite">
          {item}
        </li>
      ))}
    </ul>
  </Section>

  <InquiryCta title={text(copy, "inquiry.title")} />
</BaseLayout>
