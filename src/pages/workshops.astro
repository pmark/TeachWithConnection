---
import ButtonLink from "../components/common/ButtonLink.astro";
import InquiryCta from "../components/common/InquiryCta.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { educatorApproach, workshopTopics } from "../data/service-pages";
import { createServiceStructuredData } from "../data/site";

const description = "Workshop topics for early childhood teams, including trauma, neurodivergence, behavior, regulation, PDA, and foster care or adoption.";
---

<BaseLayout
  title="Workshops"
  description={description}
  structuredData={createServiceStructuredData("Early Childhood Educator Workshops", description, "/workshops/")}
>
  <PageHero
    eyebrow="Workshops"
    title="Practical training topics for educators and leaders"
    description="Workshops help teaching teams understand what may be driving behavior, stress, resistance, and dysregulation so they can respond with more clarity and care."
  >
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <ButtonLink href="/contact/">Bring a workshop to your team</ButtonLink>
      <ButtonLink href="/#professional-development" variant="secondary">
        Professional development overview
      </ButtonLink>
    </div>
  </PageHero>

  <Section
    eyebrow="Workshop Topics"
    title="Training themes grounded in real classroom complexity"
    description="These source-backed topics can be shaped for early childhood organizations, schools, districts, and conference audiences."
  >
    <ul class="grid gap-4 md:grid-cols-2">
      {workshopTopics.map((topic) => (
        <li class="rounded-md border border-[#e8e2dc] bg-white p-5">
          <h3 class="font-serif text-2xl leading-tight text-[#272727]">
            {topic.title}
          </h3>
          <p class="mt-3 leading-7 text-[#4f4a45]">{topic.description}</p>
        </li>
      ))}
    </ul>
  </Section>

  <Section
    background="surface"
    eyebrow="Shared Lens"
    title="The goal is not another rigid system"
    description="Across topics, the work stays focused on understanding children and educators with equal care."
  >
    <ul class="grid gap-4 md:grid-cols-2">
      {educatorApproach.map((item) => (
        <li class="border-l-4 border-[#157c93] bg-white px-5 py-4 leading-7 text-[#3c3834]">
          {item}
        </li>
      ))}
    </ul>
  </Section>

  <InquiryCta title="Bring a workshop to your team" />
</BaseLayout>
