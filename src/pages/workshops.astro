---
import ButtonLink from "../components/common/ButtonLink.astro";
import InquiryCta from "../components/common/InquiryCta.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import TestimonialQuote from "../components/proof/TestimonialQuote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { createServiceStructuredData } from "../data/site";
import { cards, getPageCopy, getSettingsCopy, getTestimonial, list, text } from "../data/content";

const copy = await getPageCopy("workshops");
const description = text(copy, "seo.description");
const testimonial = await getTestimonial("workshops-course-participant");
---

<BaseLayout
  title={text(copy, "seo.title")}
  description={description}
  structuredData={createServiceStructuredData(text(copy, "structuredData.name"), description, "/workshops/", text(await getSettingsCopy("site"), "schema.serviceAudience"))}
>
  <PageHero
    eyebrow={text(copy, "hero.eyebrow")}
    title={text(copy, "hero.title")}
    description={text(copy, "hero.description")}
  >
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <ButtonLink href="/contact/">{text(copy, "hero.primaryCta")}</ButtonLink>
      <ButtonLink href="/#professional-development" variant="secondary">
        {text(copy, "hero.secondaryCta")}
      </ButtonLink>
    </div>
    <img
      slot="image"
      src="/images/photos/kids-holding-hands.jpg"
      alt={text(copy, "hero.photoAlt")}
      width="2048"
      height="1365"
      class="aspect-[3/4] w-full max-w-sm rounded-md object-cover"
    />
  </PageHero>

  <Section title={text(copy, "problem.title")}>
    <div class="grid gap-4">
      <p class="leading-8 text-slate">{text(copy, "problem.paragraph1")}</p>
      <p class="leading-8 text-slate">{text(copy, "problem.paragraph2")}</p>
      <p class="leading-8 text-slate">{text(copy, "problem.paragraph3")}</p>
    </div>
  </Section>

  <Section background="surface" title={text(copy, "need.title")} description={text(copy, "need.lead")}>
    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div class="grid gap-4">
        <p class="leading-8 text-slate">{text(copy, "need.paragraph1")}</p>
        <p class="leading-8 text-slate">{text(copy, "need.paragraph2")}</p>
        <p class="leading-8 text-slate">{text(copy, "need.paragraph3")}</p>
      </div>
      <img
        src="/images/photos/kid-mom.jpg"
        alt="An educator kneeling down to connect with a young child outdoors"
        width="749"
        height="498"
        class="aspect-[3/2] w-full rounded-md object-cover"
      />
    </div>
  </Section>


  <section class="bg-sand bg-paper pt-4">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <TestimonialQuote quote={testimonial.quote} attribution={testimonial.attribution} />
    </div>
  </section>

  <Section
    title={text(copy, "trainings.title")}
    description={text(copy, "topics.description")}
  >
    <ul class="grid gap-4 md:grid-cols-2">
      {cards(copy, "trainings.items").map((topic) => (
        <li
          class:list={[
            "relative overflow-hidden rounded-md border bg-surface p-5",
            topic.href ? "border-clay" : "border-line",
          ]}
        >
          {topic.href && <span aria-hidden="true" class="absolute inset-x-0 top-0 h-1 bg-clay"></span>}
          {topic.href && (
            <p class="text-xs font-semibold uppercase tracking-wide text-clay-text">From Katie's Book</p>
          )}
          <h3 class:list={["font-serif text-2xl leading-tight text-charcoal", topic.href && "mt-2"]}>
            {topic.title}
          </h3>
          <p class="mt-3 leading-7 text-slate">{topic.description}</p>
          {topic.href && (
            <a href={topic.href} class="mt-3 inline-block text-sm font-semibold text-brand-text underline-offset-4 hover:underline">
              {topic.label}
            </a>
          )}
        </li>
      ))}
    </ul>
  </Section>

  <Section background="surface" eyebrow={text(copy, "lens.eyebrow")} title={text(copy, "lens.title")}>
    <div class="grid gap-8 lg:grid-cols-[1fr_1fr] lg:items-start">
      <p class="font-serif text-2xl leading-snug text-charcoal">
        {text(copy, "lens.description")}
      </p>
      <ul class="grid gap-4">
        {list(copy, "lens.items").map((item) => (
          <li class="border-l-4 border-brand-text bg-surface px-5 py-4 leading-7 text-graphite">
            {item}
          </li>
        ))}
      </ul>
    </div>
  </Section>


  <InquiryCta title={text(copy, "inquiry.title")} />
</BaseLayout>
