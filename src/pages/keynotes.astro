---
import ButtonLink from "../components/common/ButtonLink.astro";
import InquiryCta from "../components/common/InquiryCta.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { keynoteFit, keynoteTakeaways } from "../data/service-pages";
---

<BaseLayout
  title="Keynotes"
  description="Early childhood keynote speaking rooted in classroom stories, relational practice, trauma-responsive care, and practical ideas."
>
  <PageHero
    eyebrow="Keynotes"
    title="Grounded speaking for early childhood audiences"
    description="Katie's keynotes speak to educators' lived classroom experience while opening up new possibilities for connection, regulation, and relationship-centered practice."
  >
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <ButtonLink href="/contact/">Ask about a keynote</ButtonLink>
      <ButtonLink href="/publications/" variant="secondary">Review publication proof</ButtonLink>
    </div>
  </PageHero>

  <Section
    eyebrow="Audience Fit"
    title="For conferences and organizations that want warmth, rigor, and classroom relevance"
  >
    <ul class="grid gap-4 md:grid-cols-3">
      {keynoteFit.map((item) => (
        <li class="rounded-md border border-[#e8e2dc] bg-white p-5 leading-7 text-[#3c3834]">
          {item}
        </li>
      ))}
    </ul>
  </Section>

  <Section
    background="surface"
    eyebrow="Audience Experience"
    title="Stories from the field, practical ideas, and a more compassionate lens"
    description="The keynote path should help planners understand Katie's voice and subject matter without turning the page into a generic speaker pitch."
  >
    <ul class="grid gap-4 md:grid-cols-3">
      {keynoteTakeaways.map((item) => (
        <li class="border-l-4 border-[#157c93] bg-white px-5 py-4 leading-7 text-[#3c3834]">
          {item}
        </li>
      ))}
    </ul>
  </Section>

  <InquiryCta title="Ask about a keynote" />
</BaseLayout>
