---
import ButtonLink from "../components/common/ButtonLink.astro";
import InquiryCta from "../components/common/InquiryCta.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import KeynoteHeroVisual from "../components/services/KeynoteHeroVisual.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { createServiceStructuredData } from "../data/site";
import { getPageCopy, getSettingsCopy, list, text } from "../data/content";

const copy = await getPageCopy("keynotes");
const description = text(copy, "seo.description");
---

<BaseLayout
  title={text(copy, "seo.title")}
  description={description}
  structuredData={createServiceStructuredData(text(copy, "structuredData.name"), description, "/keynotes/", text(await getSettingsCopy("site"), "schema.serviceAudience"))}
>
  <PageHero
    eyebrow={text(copy, "hero.eyebrow")}
    title={text(copy, "hero.title")}
    description={text(copy, "hero.description")}
  >
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <ButtonLink href="/contact/">{text(copy, "hero.primaryCta")}</ButtonLink>
      <ButtonLink href="/publications/" variant="secondary">{text(copy, "hero.secondaryCta")}</ButtonLink>
    </div>
    <KeynoteHeroVisual
      slot="image"
      label={text(copy, "hero.visualLabel")}
      items={list(copy, "hero.visualItems")}
    />
  </PageHero>

  <Section
    eyebrow={text(copy, "audienceFit.eyebrow")}
    title={text(copy, "audienceFit.title")}
  >
    <ul class="grid gap-4 md:grid-cols-3">
      {list(copy, "audienceFit.items").map((item) => (
        <li class="rounded-md border border-line bg-surface p-5 leading-7 text-graphite">
          {item}
        </li>
      ))}
    </ul>
  </Section>

  <Section
    background="surface"
    eyebrow={text(copy, "audienceExperience.eyebrow")}
    title={text(copy, "audienceExperience.title")}
    description={text(copy, "audienceExperience.description")}
  >
    <ul class="grid gap-4 md:grid-cols-3">
      {list(copy, "audienceExperience.items").map((item) => (
        <li class="border-l-4 border-brand-text bg-surface px-5 py-4 leading-7 text-graphite">
          {item}
        </li>
      ))}
    </ul>
  </Section>

  <InquiryCta title={text(copy, "inquiry.title")} />
</BaseLayout>
