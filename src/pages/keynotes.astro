---
import InquiryCta from "../components/common/InquiryCta.astro";
import Section from "../components/common/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Keynotes"
  description="Early childhood keynote speaking rooted in classroom stories, relational practice, trauma-responsive care, and practical ideas."
>
  <Section
    eyebrow="Keynotes"
    title="Grounded speaking for early childhood audiences"
    description="Katie's keynote path should help conference planners understand her voice, audience fit, and practical classroom relevance."
  >
    <p class="max-w-3xl leading-8 text-[#4f4a45]">
      Final keynote details should use existing With Connection source content and approved testimonials from speaking or training participants.
    </p>
  </Section>
  <InquiryCta title="Ask about a keynote" />
</BaseLayout>
