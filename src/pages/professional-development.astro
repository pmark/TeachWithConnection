---
import ButtonLink from "../components/common/ButtonLink.astro";
import InquiryCta from "../components/common/InquiryCta.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  educatorApproach,
  professionalDevelopmentFocus,
  professionalDevelopmentOutcomes,
} from "../data/service-pages";
---

<BaseLayout
  title="Professional Development"
  description="Relationship-centered professional development for early childhood educators, schools, districts, and organizations."
>
  <PageHero
    eyebrow="Professional Development"
    title="Workshops and staff trainings for early childhood teams"
    description="Katie supports educators working with complex behavior, trauma histories, neurodivergence, classroom dysregulation, and the stress adults carry while trying to help."
  >
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <ButtonLink href="/contact/">Inquire about professional development</ButtonLink>
      <ButtonLink href="/workshops/" variant="secondary">View workshop topics</ButtonLink>
    </div>
  </PageHero>

  <Section
    eyebrow="Audience Fit"
    title="For teams that need a shared frame, not another generic behavior plan"
    description="Professional development should help leaders and educators make sense of what is happening beneath behavior while staying practical enough to use in real classrooms."
  >
    <ul class="grid gap-4 md:grid-cols-2">
      {professionalDevelopmentFocus.map((item) => (
        <li class="border-l-4 border-[#157c93] bg-[#f7f7f7] px-5 py-4 leading-7 text-[#3c3834]">
          {item}
        </li>
      ))}
    </ul>
  </Section>

  <Section
    background="surface"
    eyebrow="What Teams Gain"
    title="A practical path from crisis response toward connection and regulation"
  >
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="rounded-md border border-[#e8e2dc] bg-white p-6">
        <h3 class="font-serif text-2xl leading-tight text-[#272727]">
          Core approach
        </h3>
        <ul class="mt-6 grid gap-4">
          {educatorApproach.map((item) => (
            <li class="border-l-4 border-[#157c93] pl-4 leading-7 text-[#4f4a45]">
              {item}
            </li>
          ))}
        </ul>
      </div>
      <div>
        <ul class="grid gap-4">
          {professionalDevelopmentOutcomes.map((item) => (
            <li class="rounded-md border border-[#e8e2dc] bg-white p-5 leading-7 text-[#3c3834]">
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Section>

  <Section
    eyebrow="Formats"
    title="Online and in-person training shaped around your organization"
    description="Use the inquiry form to share your audience, timeline, format needs, and the classroom challenges your team is trying to understand."
  >
    <ul class="grid gap-4 md:grid-cols-3">
      {[
        "Staff professional development days",
        "Focused workshop sessions",
        "Conference breakout trainings",
      ].map((item) => (
        <li class="rounded-md border border-[#e8e2dc] bg-white p-5 leading-7 text-[#3c3834]">
          {item}
        </li>
      ))}
    </ul>
  </Section>

  <InquiryCta title="Inquire about professional development" />
</BaseLayout>
