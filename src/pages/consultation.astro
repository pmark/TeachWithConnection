---
import ButtonLink from "../components/common/ButtonLink.astro";
import InquiryCta from "../components/common/InquiryCta.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { consultationFit, educatorApproach } from "../data/service-pages";
---

<BaseLayout
  title="Consultation"
  description="Consultation for early childhood schools, centers, directors, and teaching teams facing complex classroom behavior or dysregulation."
>
  <PageHero
    eyebrow="Consultation"
    title="Support for complex classroom and team challenges"
    description="Consultation helps schools, centers, directors, and teaching teams make sense of escalating behavior, educator exhaustion, strained relationships, and classroom dysregulation."
  >
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <ButtonLink href="/contact/">Inquire about consultation</ButtonLink>
      <ButtonLink href="/professional-development/" variant="secondary">
        Explore team training
      </ButtonLink>
    </div>
  </PageHero>

  <Section
    eyebrow="When Consultation Helps"
    title="For teams that are trying hard and still feeling stuck"
    description="Consultation is a fit when current strategies are not creating enough calm, safety, or clarity for the child, the adults, or the larger classroom community."
  >
    <ul class="grid gap-4 md:grid-cols-2">
      {consultationFit.map((item) => (
        <li class="rounded-md border border-[#e8e2dc] bg-white p-5 leading-7 text-[#3c3834]">
          {item}
        </li>
      ))}
    </ul>
  </Section>

  <Section
    background="surface"
    eyebrow="Consultation Lens"
    title="Practical strategy without losing the emotional reality of the work"
  >
    <div class="grid gap-8 lg:grid-cols-[1fr_1fr]">
      <div>
        <p class="leading-8 text-[#4f4a45]">
          The work looks at both the child's experience and the educator's experience, then helps the team identify supports that are relational, trauma-responsive, neuroaffirming, and sustainable.
        </p>
        <p class="mt-5 leading-8 text-[#4f4a45]">
          The inquiry form should include enough context for Katie to understand the classroom situation, team needs, timeline, and whether consultation or broader professional development is the better fit.
        </p>
      </div>
      <ul class="grid gap-4">
        {educatorApproach.map((item) => (
          <li class="border-l-4 border-[#157c93] bg-white px-5 py-4 leading-7 text-[#3c3834]">
            {item}
          </li>
        ))}
      </ul>
    </div>
  </Section>

  <InquiryCta title="Inquire about consultation" />
</BaseLayout>
