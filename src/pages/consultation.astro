---
import ButtonLink from "../components/common/ButtonLink.astro";
import InquiryCta from "../components/common/InquiryCta.astro";
import PageHero from "../components/common/PageHero.astro";
import Section from "../components/common/Section.astro";
import TestimonialQuote from "../components/proof/TestimonialQuote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { createServiceStructuredData } from "../data/site";
import { getPageCopy, getSettingsCopy, getTestimonial, list, richList, text } from "../data/content";

const copy = await getPageCopy("consultation");
const description = text(copy, "seo.description");
const testimonial = await getTestimonial("consultation-teacher");
---

<BaseLayout
  title={text(copy, "seo.title")}
  description={description}
  structuredData={createServiceStructuredData(text(copy, "structuredData.name"), description, "/consultation/", text(await getSettingsCopy("site"), "schema.serviceAudience"))}
>
  <PageHero
    eyebrow={text(copy, "hero.eyebrow")}
    title={text(copy, "hero.title")}
    description={text(copy, "hero.description")}
  >
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <ButtonLink href="/contact/">{text(copy, "hero.primaryCta")}</ButtonLink>
      <ButtonLink href="/#professional-development" variant="secondary">
        {text(copy, "hero.secondaryCta")}
      </ButtonLink>
    </div>
    <img
      slot="image"
      src="/images/photos/katie-consultation.jpg"
      alt={text(copy, "hero.photoAlt")}
      width="1066"
      height="1600"
      class="aspect-[3/4] w-full max-w-sm rounded-md object-cover"
    />
  </PageHero>

  <Section>
    <p class="font-serif text-2xl leading-tight text-charcoal">{text(copy, "background.lead")}</p>
    <div class="mt-6 grid gap-4">
      <p class="leading-8 text-slate">{text(copy, "background.paragraph1")}</p>
      <p class="leading-8 text-slate">{text(copy, "background.paragraph2")}</p>
      <p class="leading-8 text-slate font-bold italic">{text(copy, "background.paragraph3")}</p>
    </div>
  </Section>
  <Section
    eyebrow={text(copy, "testimonial.eyebrow")}
    title={text(copy, "testimonial.title")}
    narrow
  >
    <TestimonialQuote quote={testimonial.quote} attribution={testimonial.attribution} />
  </Section>


  <Section
    eyebrow={text(copy, "fit.eyebrow")}
    title={text(copy, "fit.title")}
    description={text(copy, "fit.description")}
  >
    <ul class="grid gap-4 md:grid-cols-2">
      {richList(copy, "fit.items").map((item) => (
        <li class="rounded-md border border-line bg-surface p-5 leading-7 text-graphite">
          <p set:html={item} />
        </li>
      ))}
    </ul>
  </Section>

  <Section
    background="surface"
    eyebrow={text(copy, "lens.eyebrow")}
    title={text(copy, "lens.title")}
  >
    <div class="grid gap-8 lg:grid-cols-[1fr_1fr]">
      <div>
        <p class="leading-8 text-slate">
          {text(copy, "lens.description")}
        </p>
        <p class="mt-5 leading-8 text-slate">
          {text(copy, "lens.secondaryDescription")}
        </p>
      </div>
      <ul class="grid gap-4">
        {list(copy, "lens.items").map((item) => (
          <li class="border-l-4 border-brand-text bg-surface px-5 py-4 leading-7 text-graphite">
            {item}
          </li>
        ))}
      </ul>
    </div>
  </Section>

  
  <InquiryCta title={text(copy, "inquiry.title")} />
</BaseLayout>
