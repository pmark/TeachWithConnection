---
import ButtonLink from "../components/common/ButtonLink.astro";
import InquiryCta from "../components/common/InquiryCta.astro";
import Section from "../components/common/Section.astro";
import ProofList from "../components/proof/ProofList.astro";
import ServiceCard from "../components/services/ServiceCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { site } from "../data/site";
import { getPageCopy, getSettingsCopy, list, text } from "../data/content";

const copy = await getPageCopy("home");

const services = (await getCollection("services")).sort(
  (first, second) => first.data.priority - second.data.priority,
);
const servicePreviews = services.map(({ data }) => ({
  title: data.title,
  description: data.description,
  href: data.href,
  cta: data.cta.label,
}));

const proofTypeOrder = {
  credential: 1,
  publication: 2,
  award: 3,
  appearance: 4,
  logo: 5,
};

const proofItems = (await getCollection("proof"))
  .sort(
    (first, second) =>
      proofTypeOrder[first.data.type] - proofTypeOrder[second.data.type] ||
      first.data.title.localeCompare(second.data.title),
  )
  .map(({ data }) => data.description);

const homepageStructuredData = {
  "@type": "Service",
  "@id": `${site.url}/#professional-development-service`,
  name: text(copy, "structuredData.name"),
  description: text(copy, "structuredData.description"),
  provider: { "@id": `${site.url}/#organization` },
  areaServed: { "@type": "Country", name: "United States" },
  audience: {
    "@type": "Audience",
    audienceType: text(await getSettingsCopy("site"), "schema.serviceAudience"),
  },
  url: site.url,
};
---

<BaseLayout
  title={text(copy, "seo.title")}
  titleSuffix={false}
  canonicalPath="/"
  description={text(copy, "seo.description")}
  structuredData={homepageStructuredData}
>
  <section class="bg-[#f7f7f7] py-12 sm:py-16 lg:py-20">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-center lg:gap-12">
      <div>
        <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-[#157c93]">
          {text(copy, "hero.eyebrow")}
        </p>
        <h1 class="font-serif text-4xl leading-tight text-[#272727] sm:text-5xl lg:text-6xl">
          {text(copy, "hero.title")}
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-[#4f4a45]">
          {text(copy, "hero.description")}
        </p>
        <p class="mt-4 max-w-2xl leading-7 text-[#4f4a45]">
          {text(copy, "hero.secondaryDescription")}
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <ButtonLink href="/contact/">{text(copy, "hero.primaryCta")}</ButtonLink>
          <ButtonLink href="/workshops/" variant="secondary">{text(copy, "hero.secondaryCta")}</ButtonLink>
        </div>
      </div>

      <aside class="rounded-md border border-[#e8e2dc] bg-white p-6" aria-label={text(copy, "credibility.ariaLabel")}>
        <p class="font-serif text-3xl leading-tight text-[#272727]">
          {text(copy, "credibility.title")}
        </p>
        <dl class="mt-8 grid gap-5">
          <div>
            <dt class="text-sm font-semibold uppercase tracking-wide text-[#157c93]">{text(copy, "credibility.credentialsLabel")}</dt>
            <dd class="mt-1 text-[#4f4a45]">{text(copy, "credibility.credentials")}</dd>
          </div>
          <div>
            <dt class="text-sm font-semibold uppercase tracking-wide text-[#157c93]">{text(copy, "credibility.publicationLabel")}</dt>
            <dd class="mt-1 text-[#4f4a45]">
              {text(copy, "credibility.publicationPrefix")} <cite>{text(copy, "credibility.publication")}</cite>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-semibold uppercase tracking-wide text-[#157c93]">{text(copy, "credibility.approachLabel")}</dt>
            <dd class="mt-1 text-[#4f4a45]">
              {text(copy, "credibility.approach")}
            </dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>

  <div id="professional-development" class="scroll-mt-6">
    <Section
      eyebrow={text(copy, "professionalDevelopment.eyebrow")}
      title={text(copy, "professionalDevelopment.title")}
      description={text(copy, "professionalDevelopment.description")}
    >
      <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr]">
        <div>
          <h3 class="font-serif text-2xl leading-tight text-[#272727]">{text(copy, "professionalDevelopment.fitTitle")}</h3>
          <ul class="mt-5 grid gap-3">
            {list(copy, "professionalDevelopment.focus").map((item) => (
              <li class="border-l-4 border-[#157c93] bg-[#f7f7f7] px-4 py-3 leading-7 text-[#3c3834]">
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-md border border-[#e8e2dc] bg-white p-5 sm:p-6">
          <h3 class="font-serif text-2xl leading-tight text-[#272727]">{text(copy, "professionalDevelopment.outcomesTitle")}</h3>
          <ul class="mt-5 grid gap-4">
            {list(copy, "professionalDevelopment.outcomes").map((item) => (
              <li class="leading-7 text-[#4f4a45]">{item}</li>
            ))}
          </ul>
        </div>
      </div>
      <div class="mt-10">
        <h3 class="font-serif text-2xl leading-tight text-[#272727]">{text(copy, "professionalDevelopment.formatsTitle")}</h3>
        <ul class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {list(copy, "professionalDevelopment.formats").map((item) => (
            <li class="rounded-md border border-[#e8e2dc] bg-white p-5 leading-7 text-[#3c3834]">{item}</li>
          ))}
        </ul>
      </div>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <ButtonLink href="/workshops/">{text(copy, "professionalDevelopment.primaryCta")}</ButtonLink>
        <ButtonLink href="/contact/" variant="secondary">{text(copy, "professionalDevelopment.secondaryCta")}</ButtonLink>
      </div>
    </Section>
  </div>

  <Section
    background="surface"
    eyebrow={text(copy, "services.eyebrow")}
    title={text(copy, "services.title")}
    description={text(copy, "services.description")}
  >
    <div class="grid gap-5 md:grid-cols-2">
      {servicePreviews.map((service) => <ServiceCard {...service} />)}
    </div>
  </Section>

  <Section
    background="surface"
    eyebrow={text(copy, "proof.eyebrow")}
    title={text(copy, "proof.title")}
  >
    <ProofList items={proofItems} />
  </Section>

  <Section
    eyebrow={text(copy, "approach.eyebrow")}
    title={text(copy, "approach.title")}
  >
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1fr] lg:items-start">
      <aside class="rounded-md border border-[#e8e2dc] bg-white p-6">
        <h3 class="font-serif text-2xl leading-tight text-[#272727]">
          {text(copy, "approach.testimonialTitle")}
        </h3>
        <p class="mt-4 leading-7 text-[#4f4a45]">
          {text(copy, "approach.testimonialEmpty")}
        </p>
      </aside>
      <div>
        <p class="leading-8 text-[#4f4a45]">
          {text(copy, "approach.description")}
        </p>
        <p class="mt-5 leading-8 text-[#4f4a45]">
          {text(copy, "approach.secondaryDescription")}
        </p>
      </div>
    </div>
  </Section>

  <Section
    background="surface"
    eyebrow={text(copy, "resources.eyebrow")}
    title={text(copy, "resources.title")}
    description={text(copy, "resources.description")}
  >
    <div class="rounded-md border border-[#e8e2dc] bg-white p-6">
      <p class="leading-7 text-[#4f4a45]">
        {text(copy, "resources.empty")}
      </p>
      <div class="mt-6">
        <ButtonLink href="/resources/" variant="secondary">{text(copy, "resources.cta")}</ButtonLink>
      </div>
    </div>
  </Section>

  <InquiryCta />
</BaseLayout>
